<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="site-footer__grid">
      <div class="site-footer__brand">
        <div class="site-header__logo">
          <span class="dot" aria-hidden="true"></span>{{ section.settings.brand_text | default: shop.name }}
        </div>
        <p>{{ section.settings.tagline }}</p>
      </div>

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'link_list' -%}
            <div class="site-footer__col" {{ block.shopify_attributes }}>
              <h4>{{ block.settings.heading }}</h4>
              <ul>
                {%- for link in linklists[block.settings.menu].links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            </div>
          {%- when 'newsletter' -%}
            <div class="site-footer__col" {{ block.shopify_attributes }}>
              <h4>{{ block.settings.heading }}</h4>
              <p style="color: var(--text-dim); font-size: .9rem; margin-bottom: 1rem;">{{ block.settings.subtext }}</p>
              {%- form 'customer', class: 'cb-form', style: 'padding:0;border:0;background:transparent;grid-template-columns:1fr;' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <input type="email" name="contact[email]" placeholder="Email" required>
                <button class="btn btn--primary" type="submit">Subscribe</button>
              {%- endform -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <div class="site-footer__bottom">
      <span>© {{ 'now' | date: '%Y' }} {{ shop.name }}</span>
      <div class="site-footer__social">
        {%- if settings.social_instagram != blank -%}<a href="{{ settings.social_instagram }}" aria-label="Instagram"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="4"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".5" fill="currentColor"/></svg></a>{%- endif -%}
        {%- if settings.social_youtube != blank -%}<a href="{{ settings.social_youtube }}" aria-label="YouTube"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="6" width="20" height="12" rx="3"/><path d="m10 9 5 3-5 3z" fill="currentColor"/></svg></a>{%- endif -%}
        {%- if settings.social_x != blank -%}<a href="{{ settings.social_x }}" aria-label="X"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 3h3l-7 8 8 10h-6l-5-6-5 6H3l7-9-8-9h6l4 5z"/></svg></a>{%- endif -%}
        {%- if settings.social_discord != blank -%}<a href="{{ settings.social_discord }}" aria-label="Discord"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19 5a16 16 0 0 0-4-1l-.2.4a14 14 0 0 0-5.6 0L9 4a16 16 0 0 0-4 1A18 18 0 0 0 2 17a17 17 0 0 0 5 2l1-1.5a11 11 0 0 1-2-1l.5-.3a12 12 0 0 0 11 0l.5.3a11 11 0 0 1-2 1l1 1.5a17 17 0 0 0 5-2 18 18 0 0 0-3-12ZM9 14a2 2 0 1 1 0-4 2 2 0 0 1 0 4Zm6 0a2 2 0 1 1 0-4 2 2 0 0 1 0 4Z"/></svg></a>{%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "brand_text", "label": "Brand text", "default": "SULLYPC" },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Custom builds. Curated parts. Shipped from the bench." }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Link list",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu", "default": "footer" }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Subscribe" },
        { "type": "text", "id": "subtext", "label": "Subtext", "default": "New drops, build logs, parts deals — once a month." }
      ]
    }
  ]
}
{% endschema %}
