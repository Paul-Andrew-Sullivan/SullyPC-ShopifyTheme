<section class="section">
  <div class="container">
    <div class="section__head reveal">
      <div>
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 style="margin-top:.8rem;">{{ section.settings.heading }}</h2>
        {%- if section.settings.lede != blank -%}<p class="lede">{{ section.settings.lede }}</p>{%- endif -%}
      </div>
      {%- if section.settings.cta_text != blank -%}<a class="btn" href="{{ section.settings.cta_link }}">{{ section.settings.cta_text }} →</a>{%- endif -%}
    </div>

    {%- assign collection = collections[section.settings.collection] -%}
    {%- if collection != blank and collection.products.size > 0 -%}
      <div class="mv-grid reveal">
        {%- for product in collection.products limit: section.settings.product_limit -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="mv-grid reveal">
        {%- assign placeholders = 'collection-1,collection-2,collection-3,collection-4,collection-5,collection-6' | split: ',' -%}
        {%- for i in placeholders limit: section.settings.product_limit -%}
          <a class="mv-card" href="#">
            <div class="mv-card__media">{{ i | placeholder_svg_tag: 'placeholder-svg' }}</div>
            <div class="mv-card__overlay"></div>
            <div class="mv-card__corner"></div>
            <div class="mv-card__body">
              <div class="mv-card__title">Sample part {{ forloop.index }}</div>
              <div class="mv-card__price">$—</div>
              <div class="mv-card__desc">Connect a collection in the theme editor to populate this grid.</div>
              <div class="mv-card__quick"><span class="btn">View</span></div>
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "ON THE SHELF" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured parts" },
    { "type": "textarea", "id": "lede", "label": "Lede" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_limit", "label": "Items", "min": 4, "max": 12, "step": 1, "default": 8 },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "All parts" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}
