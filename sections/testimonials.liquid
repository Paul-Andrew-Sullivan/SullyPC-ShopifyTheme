<section class="section testimonials-section">
  <div class="container">
    <div class="section__head reveal" style="margin-bottom:2rem;">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 style="margin-top:.8rem;">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="testimonial-grid reveal">
        {%- for block in section.blocks -%}
          <figure class="testimonial" {{ block.shopify_attributes }}>
            <blockquote class="testimonial__quote">{{ block.settings.quote }}</blockquote>
            <figcaption class="testimonial__meta">
              <span class="testimonial__name">{{ block.settings.name }}</span>
              {%- if block.settings.location != blank -%}
                <span class="testimonial__loc">{{ block.settings.location }}</span>
              {%- endif -%}
              {%- if block.settings.build != blank -%}
                <span class="testimonial__build">{{ block.settings.build }}</span>
              {%- endif -%}
            </figcaption>
          </figure>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "REVIEWS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "From people who've bought from me." }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "I was nervous dropping $3k with a solo builder, but they walked me through every part choice and sent progress photos. Machine runs like a dream six months later." },
        { "type": "text", "id": "name", "label": "First name", "default": "Marcus" },
        { "type": "text", "id": "location", "label": "Location", "default": "Austin, TX" },
        { "type": "text", "id": "build", "label": "Build / item", "default": "Custom Gaming/Streaming PC" }
      ]
    }
  ],
  "max_blocks": 9,
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "quote" },
        { "type": "quote" },
        { "type": "quote" }
      ]
    }
  ]
}
{% endschema %}
