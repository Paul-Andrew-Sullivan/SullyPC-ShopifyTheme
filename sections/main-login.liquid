<section class="section">
  <div class="container" style="max-width:520px;">
    <div class="reveal" style="margin-bottom:2rem;text-align:center;">
      <span class="eyebrow" style="justify-content:center;">SIGN IN</span>
      <h1 style="margin-top:.8rem;">Welcome back</h1>
    </div>
    {%- form 'customer_login', class: 'cb-form', style: 'grid-template-columns:1fr;' -%}
      {%- if form.errors -%}<p class="field--full" style="color:var(--danger);">{{ form.errors | default_errors }}</p>{%- endif -%}
      <div class="field"><label>Email</label><input type="email" name="customer[email]" required></div>
      <div class="field"><label>Password</label><input type="password" name="customer[password]" required></div>
      <div class="field"><button type="submit" class="btn btn--primary btn--block">Sign in</button></div>
      <p class="field--full" style="text-align:center;color:var(--text-dim);font-size:.9rem;">
        New here? <a href="{{ routes.account_register_url }}" style="color:var(--accent);">Create an account</a>
        · <a href="{{ routes.account_recover_url }}" style="color:var(--text-dim);">Forgot password</a>
      </p>
    {%- endform -%}
  </div>
</section>
{% schema %}{ "name": "Login", "settings": [] }{% endschema %}
