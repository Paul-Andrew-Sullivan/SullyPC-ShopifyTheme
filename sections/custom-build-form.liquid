<section class="cb-hero">
  <div class="container cb-hero__inner">
    <span class="eyebrow">{{ section.settings.eyebrow }}</span>
    <h1 style="margin-top:1rem;max-width:18ch;">{{ section.settings.heading }}</h1>
    {%- if section.settings.lede != blank -%}
      <p class="lede">{{ section.settings.lede }}</p>
    {%- endif -%}
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section__head reveal" style="margin-bottom:1.5rem;">
      <div>
        <span class="eyebrow">HOW IT WORKS</span>
        <h2 style="margin-top:.8rem;">Four steps, two to three weeks.</h2>
      </div>
    </div>
    <div class="process reveal">
      <div class="process__step">
        <span class="process__num">01 / BRIEF</span>
        <h3>You send the brief</h3>
        <p>Budget, use case, aesthetic — whatever you want me to know. Form below, no commitment.</p>
      </div>
      <div class="process__step">
        <span class="process__num">02 / QUOTE</span>
        <h3>I send a parts list</h3>
        <p>Within 48 hours. Itemized parts, total cost, build timeline. Approve, revise, or walk away.</p>
      </div>
      <div class="process__step">
        <span class="process__num">03 / BUILD</span>
        <h3>I build &amp; test</h3>
        <p>Hand-assembled, cabled, and burn-in tested 24h with full benchmark data sent to you.</p>
      </div>
      <div class="process__step">
        <span class="process__num">04 / SHIP</span>
        <h3>Custom-foam crated</h3>
        <p>Insured shipping, signed delivery. 12-month warranty starts the day it arrives.</p>
      </div>
    </div>
  </div>
</section>

<section class="section" style="padding-top:0;">
  <div class="container">
    <div class="section__head reveal" style="margin-bottom:1.5rem;">
      <div>
        <span class="eyebrow">STARTING POINTS</span>
        <h2 style="margin-top:.8rem;">Three rough tiers.</h2>
        <p class="lede">A frame for the conversation — every commission gets a custom parts list.</p>
      </div>
    </div>
    <div class="tier-grid reveal">
      <div class="tier">
        <span class="eyebrow">TIER 01</span>
        <h3>Workhorse</h3>
        <div class="price">$1,800<small> – $2,500</small></div>
        <p style="color:var(--text-dim);">Solid 1440p gaming or general productivity. Mid-range CPU + GPU, quiet cooling, room to grow.</p>
        <ul>
          <li>Ryzen 7 / Core i5 class</li>
          <li>RTX 4070 / equivalent</li>
          <li>32GB DDR5, 2TB NVMe</li>
          <li>Air cooling, mid tower</li>
        </ul>
      </div>
      <div class="tier tier--featured">
        <span class="eyebrow">TIER 02</span>
        <h3>Apex</h3>
        <div class="price">$3,200<small> – $4,500</small></div>
        <p style="color:var(--text-dim);">High-refresh 4K, streaming, light content work. The build most people end up with.</p>
        <ul>
          <li>Ryzen 9 / Core i9 class</li>
          <li>RTX 4080 Super / 4090</li>
          <li>64GB DDR5, 4TB NVMe</li>
          <li>360mm AIO, premium chassis</li>
          <li>Custom cabling</li>
        </ul>
      </div>
      <div class="tier">
        <span class="eyebrow">TIER 03</span>
        <h3>Studio</h3>
        <div class="price">$5,500<small>+</small></div>
        <p style="color:var(--text-dim);">Render workstations, scientific compute, watercooled showpieces. Built around your brief.</p>
        <ul>
          <li>Threadripper / Xeon W</li>
          <li>RTX 4090 / pro GPU</li>
          <li>128GB+ ECC RAM</li>
          <li>Custom hardline loop available</li>
          <li>Whatever the brief calls for</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<section class="section" style="padding-top:0;">
  <div class="container">
    <div class="cb-layout reveal">

      <div>
        <span class="eyebrow">SEND A BRIEF</span>
        <h2 style="margin-top:.8rem;">Start the conversation.</h2>
        <p style="color:var(--text-dim);margin-top:1rem;">No commitment. The more detail you give me — references, constraints, weird requirements — the tighter the quote will be.</p>
        <div style="margin-top:2rem;display:flex;flex-direction:column;gap:1rem;font-size:.9rem;color:var(--text-dim);">
          <div><strong style="color:var(--text);">Reply time</strong><br>{{ section.settings.reply_time }}</div>
          <div><strong style="color:var(--text);">Build time</strong><br>{{ section.settings.build_time }}</div>
          <div><strong style="color:var(--text);">Deposit</strong><br>{{ section.settings.deposit_info }}</div>
        </div>
      </div>

      {%- form 'contact' -%}
        <div class="cb-form">
          <input type="hidden" name="contact[tags]" value="custom-build">

          <div class="field">
            <label for="cb-name">Your name</label>
            <input type="text" id="cb-name" name="contact[name]" placeholder="Jane Doe" required>
          </div>
          <div class="field">
            <label for="cb-email">Email</label>
            <input type="email" id="cb-email" name="contact[email]" placeholder="jane@example.com" required>
          </div>

          <div class="field field--full">
            <label>What's this build for?</label>
            <div class="chip-row">
              <input type="checkbox" id="cb-u1" name="contact[use_gaming_1440p]" value="Gaming 1440p"><label for="cb-u1">Gaming 1440p</label>
              <input type="checkbox" id="cb-u2" name="contact[use_gaming_4k]" value="Gaming 4K"><label for="cb-u2">Gaming 4K</label>
              <input type="checkbox" id="cb-u3" name="contact[use_streaming]" value="Streaming"><label for="cb-u3">Streaming</label>
              <input type="checkbox" id="cb-u4" name="contact[use_3d_render]" value="3D Render"><label for="cb-u4">3D / render</label>
              <input type="checkbox" id="cb-u5" name="contact[use_video_editing]" value="Video editing"><label for="cb-u5">Video editing</label>
              <input type="checkbox" id="cb-u6" name="contact[use_ml]" value="ML Compute"><label for="cb-u6">ML / compute</label>
              <input type="checkbox" id="cb-u7" name="contact[use_work]" value="General work"><label for="cb-u7">General work</label>
              <input type="checkbox" id="cb-u8" name="contact[use_showpiece]" value="Showpiece"><label for="cb-u8">Showpiece</label>
            </div>
          </div>

          <div class="field">
            <label for="cb-budget">Budget</label>
            <select id="cb-budget" name="contact[Budget]">
              <option>$1,800 – $2,500 (Workhorse)</option>
              <option>$3,200 – $4,500 (Apex)</option>
              <option>$5,500+ (Studio)</option>
              <option>Flexible / not sure yet</option>
            </select>
          </div>
          <div class="field">
            <label for="cb-timeline">Timeline</label>
            <select id="cb-timeline" name="contact[Timeline]">
              <option>Standard (2–3 weeks)</option>
              <option>Rush (priced separately)</option>
              <option>Flexible</option>
            </select>
          </div>

          <div class="field field--full">
            <label>Aesthetic preferences</label>
            <div class="chip-row">
              <input type="checkbox" id="cb-a1" name="contact[ae_black]" value="All-black"><label for="cb-a1">All-black</label>
              <input type="checkbox" id="cb-a2" name="contact[ae_white]" value="White / minimal"><label for="cb-a2">White / minimal</label>
              <input type="checkbox" id="cb-a3" name="contact[ae_rgb]" value="RGB"><label for="cb-a3">RGB</label>
              <input type="checkbox" id="cb-a4" name="contact[ae_norgb]" value="No RGB"><label for="cb-a4">No RGB</label>
              <input type="checkbox" id="cb-a5" name="contact[ae_itx]" value="ITX small"><label for="cb-a5">ITX / small</label>
              <input type="checkbox" id="cb-a6" name="contact[ae_showcase]" value="Showcase chassis"><label for="cb-a6">Showcase chassis</label>
              <input type="checkbox" id="cb-a7" name="contact[ae_water]" value="Watercooled"><label for="cb-a7">Watercooled</label>
            </div>
          </div>

          <div class="field field--full">
            <label for="cb-brief">The brief</label>
            <textarea id="cb-brief" name="contact[body]" placeholder="What are you trying to do? Anything you specifically want or want to avoid? Reference rigs you like? Tell me anything."></textarea>
          </div>

          {%- if form.posted_successfully? -%}
            <p class="field--full" style="color:var(--accent);grid-column:1 / -1;">Thanks — I'll be in touch within 48 hours.</p>
          {%- endif -%}

          <div class="field field--full" style="display:flex;justify-content:flex-end;">
            <button type="submit" class="btn btn--primary">Send brief →</button>
          </div>
        </div>
      {%- endform -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom Build",
  "settings": [
    { "type": "text",     "id": "eyebrow",     "label": "Hero eyebrow",  "default": "COMMISSION A BUILD" },
    { "type": "text",     "id": "heading",     "label": "Hero heading",  "default": "Tell me what you want. I'll build it." },
    { "type": "textarea", "id": "lede",        "label": "Hero lede",     "default": "Send a brief and you'll get a full parts list with quote within 48 hours. Build time is typically 2-3 weeks." },
    { "type": "text",     "id": "reply_time",  "label": "Reply time",    "default": "48 hours, weekdays." },
    { "type": "text",     "id": "build_time",  "label": "Build time",    "default": "2-3 weeks once approved." },
    { "type": "text",     "id": "deposit_info","label": "Deposit",       "default": "30% on parts order, balance on completion." }
  ]
}
{% endschema %}
