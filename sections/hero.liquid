<section class="hero">
  <div class="hero__grid" aria-hidden="true"></div>
  <div class="hero__glow" aria-hidden="true"></div>
  <div class="container hero__inner">
    <div class="reveal">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h1 style="margin-top:1.2rem;">{{ section.settings.heading }}</h1>
      {%- if section.settings.sub != blank -%}<p class="hero__sub">{{ section.settings.sub }}</p>{%- endif -%}
      <div class="hero__cta">
        {%- if section.settings.cta1_text != blank -%}<a href="{{ section.settings.cta1_link }}" class="btn btn--primary">{{ section.settings.cta1_text }} →</a>{%- endif -%}
        {%- if section.settings.cta2_text != blank -%}<a href="{{ section.settings.cta2_link }}" class="btn">{{ section.settings.cta2_text }}</a>{%- endif -%}
      </div>
    </div>
    <div class="hero__stats reveal">
      {%- for block in section.blocks -%}
        <div class="hero__stat" {{ block.shopify_attributes }}>
          <span class="num">{{ block.settings.value }}</span>
          <span class="lbl">{{ block.settings.label }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "BUILT TO ORDER · 2026 SEASON" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Custom rigs. Curated parts. Real performance." },
    { "type": "textarea", "id": "sub", "label": "Sub", "default": "Pre-built workstations, hand-tested components, and bespoke commissions for builders who want it done right." },
    { "type": "text", "id": "cta1_text", "label": "Primary CTA", "default": "Shop builds" },
    { "type": "url",  "id": "cta1_link", "label": "Primary link" },
    { "type": "text", "id": "cta2_text", "label": "Secondary CTA", "default": "Browse parts" },
    { "type": "url",  "id": "cta2_link", "label": "Secondary link" }
  ],
  "blocks": [{
    "type": "stat", "name": "Stat", "limit": 4,
    "settings": [
      { "type": "text", "id": "value", "label": "Value", "default": "120+" },
      { "type": "text", "id": "label", "label": "Label", "default": "Builds shipped" }
    ]
  }],
  "presets": [{ "name": "Hero", "blocks": [{"type":"stat"},{"type":"stat"},{"type":"stat"},{"type":"stat"}] }]
}
{% endschema %}
