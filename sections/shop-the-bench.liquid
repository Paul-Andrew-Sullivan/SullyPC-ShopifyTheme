<section class="section">
  <div class="container">
    <div class="section__head reveal">
      <div>
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 style="margin-top:.8rem;">{{ section.settings.heading }}</h2>
        {%- if section.settings.lede != blank -%}<p class="lede">{{ section.settings.lede }}</p>{%- endif -%}
      </div>
      {%- if section.settings.cta_text != blank -%}<a class="btn" href="{{ section.settings.cta_link }}">{{ section.settings.cta_text }} →</a>{%- endif -%}
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);" class="reveal">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="mv-card" style="aspect-ratio:1/1;" {{ block.shopify_attributes }}>
          <div class="mv-card__media">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 1000 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
            {%- else -%}
              <div style="position:absolute;inset:0;background:linear-gradient(135deg,var(--surface-2),var(--surface));"></div>
            {%- endif -%}
          </div>
          <div class="mv-card__overlay"></div>
          <div class="mv-card__corner"></div>
          <div class="mv-card__body">
            <span class="eyebrow" style="margin-bottom:.5rem;">{{ block.settings.kicker }}</span>
            <div class="mv-card__title" style="font-size:1.5rem;">{{ block.settings.title }}</div>
            <div class="mv-card__desc">{{ block.settings.sub }}</div>
            <div class="mv-card__quick"><span class="btn">{{ block.settings.cta | default: 'Shop' }} →</span></div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
@media (max-width: 800px) {
  .section [style*="grid-template-columns:repeat(3"] { grid-template-columns: 1fr !important; }
}
</style>

{% schema %}
{
  "name": "Shop the bench",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "WHAT YOU'RE HERE FOR" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop the bench" },
    { "type": "textarea", "id": "lede", "label": "Lede" },
    { "type": "text", "id": "cta_text", "label": "CTA text" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "blocks": [{
    "type": "tile", "name": "Tile", "limit": 6,
    "settings": [
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "text", "id": "kicker", "label": "Kicker", "default": "01" },
      { "type": "text", "id": "title", "label": "Title", "default": "Full Builds" },
      { "type": "textarea", "id": "sub", "label": "Sub", "default": "Pre-built rigs, ready to ship." },
      { "type": "text", "id": "cta", "label": "CTA", "default": "Shop builds" },
      { "type": "url", "id": "link", "label": "Link" }
    ]
  }],
  "presets": [{
    "name": "Shop the bench",
    "blocks": [
      { "type": "tile", "settings": { "kicker": "01", "title": "Full Builds",   "sub": "Pre-built rigs, ready to ship.",      "cta": "Shop builds" } },
      { "type": "tile", "settings": { "kicker": "02", "title": "Parts",         "sub": "Curated GPUs, CPUs, boards, memory.", "cta": "Shop parts" } },
      { "type": "tile", "settings": { "kicker": "03", "title": "Custom Build",  "sub": "Commission a one-of-one rig.",        "cta": "Start brief" } }
    ]
  }]
}
{% endschema %}
