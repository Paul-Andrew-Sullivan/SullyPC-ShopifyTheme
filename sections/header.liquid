{% comment %} Header section — appears in header-group {% endcomment %}
<header class="site-header" role="banner">
  <div class="container site-header__bar">
    <a href="{{ routes.root_url }}" class="site-header__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: section.settings.logo_width | times: 2 }}"
             alt="{{ shop.name }}" width="{{ section.settings.logo_width }}" loading="eager">
      {%- else -%}
        <span class="dot" aria-hidden="true"></span>{{ section.settings.brand_text | default: shop.name }}
      {%- endif -%}
    </a>

    <nav class="site-nav" data-site-nav aria-label="Primary">
      {%- for link in linklists[section.settings.menu].links -%}
        <a href="{{ link.url }}" {% if link.active %}class="is-active"{% endif %}>{{ link.title }}</a>
      {%- endfor -%}
    </nav>

    <div class="site-header__actions">
      <a href="{{ routes.search_url }}" class="icon-btn" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
      </a>
      <a href="{{ routes.account_url }}" class="icon-btn" aria-label="Account">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/></svg>
      </a>
      <a href="{{ routes.cart_url }}" class="icon-btn" aria-label="Cart">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 6h15l-2 11H7L5 6Z"/><path d="M5 6 4 3H2"/><circle cx="9" cy="21" r="1.4"/><circle cx="17" cy="21" r="1.4"/></svg>
        <span class="badge" data-cart-count {% if cart.item_count == 0 %}style="display:none"{% endif %}>{{ cart.item_count }}</span>
      </a>
      <button class="icon-btn menu-toggle" data-menu-toggle aria-label="Menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
      </button>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "range", "id": "logo_width", "label": "Logo width", "min": 80, "max": 240, "step": 10, "unit": "px", "default": 140 },
    { "type": "text", "id": "brand_text", "label": "Brand text (if no logo)", "default": "SULLYPC" },
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" }
  ]
}
{% endschema %}
