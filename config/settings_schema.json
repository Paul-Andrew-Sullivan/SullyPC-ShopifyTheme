        "max": 1800,
        "step": 20,
        "unit": "px",
        "default": 1480
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      { "type": "color", "id": "color_bg",          "label": "Background",       "default": "#0a0e14" },
      { "type": "color", "id": "color_surface",     "label": "Surface",          "default": "#11151c" },
      { "type": "color", "id": "color_surface_2",   "label": "Surface (raised)", "default": "#171c25" },
      { "type": "color", "id": "color_border",      "label": "Border",           "default": "#1f2530" },
      { "type": "color", "id": "color_text",        "label": "Text",             "default": "#e8ecf2" },
      { "type": "color", "id": "color_text_dim",    "label": "Text dim",         "default": "#8a93a3" },
      { "type": "color", "id": "color_accent",      "label": "Accent",           "default": "#6b8eff" },
      { "type": "color", "id": "color_accent_hot",  "label": "Accent hover",     "default": "#88a4ff" }
    ]
  },
  {
