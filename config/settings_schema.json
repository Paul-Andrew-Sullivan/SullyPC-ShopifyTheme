        "default": 1480
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      { "type": "color", "id": "color_bg",         "label": "Background",       "default": "#FFFFFF" },
      { "type": "color", "id": "color_surface",    "label": "Surface",          "default": "#F4F3F7" },
      { "type": "color", "id": "color_surface_2",  "label": "Surface (raised)", "default": "#ECEAF1" },
      { "type": "color", "id": "color_border",     "label": "Border",           "default": "#1f2530" },
      { "type": "color", "id": "color_text",       "label": "Text",             "default": "#1A1A1A" },
      { "type": "color", "id": "color_text_dim",   "label": "Text dim",         "default": "#6B6B6B" },
      { "type": "color", "id": "color_accent",     "label": "Accent",           "default": "#4D3F66" },
      { "type": "color", "id": "color_accent_hot", "label": "Accent hover",     "default": "#3A2E50" }
    ]
  },
  {
