    "settings": [
      { "type": "font_picker", "id": "heading_font", "label": "Heading", "default": "spectral_n6" },
      { "type": "font_picker", "id": "body_font",    "label": "Body",    "default": "assistant_n4" },
      { "type": "font_picker", "id": "mono_font",    "label": "Mono",    "default": "assistant_n4" }
