<section class="section">
  <div class="container" style="max-width:520px;">
    <div class="reveal" style="margin-bottom:2rem;text-align:center;">
      <span class="eyebrow" style="justify-content:center;">RESET PASSWORD</span>
      <h1 style="margin-top:.8rem;">Forgot password?</h1>
      <p style="color:var(--text-dim);margin-top:.8rem;">We'll send you a link to reset it.</p>
    </div>
    {%- form 'recover_customer_password', class: 'cb-form', style: 'grid-template-columns:1fr;' -%}
      {%- if form.posted_successfully? -%}<p style="color:var(--accent);">Check your email.</p>{%- endif -%}
      <div class="field"><label>Email</label><input type="email" name="email" required></div>
      <div class="field"><button type="submit" class="btn btn--primary btn--block">Send reset link</button></div>
    {%- endform -%}
  </div>
</section>
